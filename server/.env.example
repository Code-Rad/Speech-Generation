# ─────────────────────────────────────────────────────────────────────────────
# VoiceForge — Environment Configuration Example
# Copy this file to server/.env and fill in your values.
# NEVER commit server/.env to git (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── Phase Control ─────────────────────────────────────────────────────────────
# "1" = Phase 1 only: XTTS v2 + Edge TTS (Windows native, no WSL2 needed)
# "2" = Phase 2: Voxtral + Fish S2 Pro active (requires WSL2 on TRIJYA-7)
VOICEFORGE_PHASE=1

# ── Engine Selection ──────────────────────────────────────────────────────────
# Primary engines per language (used only in Phase 2).
# In Phase 1, XTTS v2 is always used regardless of these settings.
ENGINE_ENGLISH_PRIMARY=fish_s2_pro
ENGINE_HINDI_PRIMARY=voxtral_tts
ENGINE_HINGLISH_PRIMARY=voxtral_tts

# Fallback (when primary is unavailable). Do not change unless you add a new engine.
ENGINE_FALLBACK=xtts_v2

# Emergency (last resort, always available, draft quality only).
ENGINE_EMERGENCY=edge_tts

# ── Server Paths ──────────────────────────────────────────────────────────────
# Relative to C:\VoiceForge\ (the project root).
VOICE_PROFILES_DIR=server/voice_profiles
REFERENCE_AUDIO_DIR=server/reference_audio
OUTPUT_DIR=server/output

# ── XTTS v2 Settings ──────────────────────────────────────────────────────────
# Model name as recognised by the Coqui TTS library.
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
# Set to False to run XTTS on CPU (very slow — GPU recommended).
XTTS_USE_GPU=True

# ── Voxtral TTS Settings (Phase 2) ───────────────────────────────────────────
# vLLM-Omni is started inside WSL2 on TRIJYA-7.
# WSL2 exposes its ports to Windows on localhost — no Tailscale IP needed.
VOXTRAL_HOST=localhost
VOXTRAL_PORT=8091
VOXTRAL_MODEL=mistralai/Voxtral-4B-TTS-2603
# Generation timeout in seconds (Voxtral is slow on first run).
VOXTRAL_TIMEOUT=120

# ── Fish S2 Pro Settings (Phase 2) ───────────────────────────────────────────
# SGLang is started inside WSL2 on TRIJYA-7.
FISH_HOST=localhost
FISH_PORT=8092
FISH_MODEL=fishaudio/s2-pro
FISH_TIMEOUT=120

# ── Audio Output ──────────────────────────────────────────────────────────────
# Default format for generated audio (wav or mp3).
DEFAULT_OUTPUT_FORMAT=wav
# Sample rate in Hz. 24000 matches XTTS v2 native output.
DEFAULT_SAMPLE_RATE=24000

# ── Edge TTS Voice Names ──────────────────────────────────────────────────────
# Microsoft Neural voice identifiers used for emergency fallback.
# Full list: https://learn.microsoft.com/azure/cognitive-services/speech/language-support
EDGE_TTS_VOICE_EN_MALE=en-US-GuyNeural
EDGE_TTS_VOICE_EN_FEMALE=en-US-JennyNeural
EDGE_TTS_VOICE_HI_MALE=hi-IN-MadhurNeural
EDGE_TTS_VOICE_HI_FEMALE=hi-IN-SwaraNeural
